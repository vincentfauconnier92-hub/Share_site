# Variables d'environnement du service backend uniquement.
# Copier vers .env.backend et remplir les valeurs.

# ── Application ─────────────────────────────────────────────────────
ENV=development
# Générer : python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me_in_production
API_SECRET_KEY=change_me_api_key
DATABASE_URL=postgresql://trading:change_me_strong_password@db:5432/trading
FRONTEND_URL=http://localhost:3000
# Générer : python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_EXPIRE_HOURS=24

# ── Alpaca (Paper Trading) ──────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Binance (Testnet) ────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
