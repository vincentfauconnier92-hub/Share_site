# Variables d'environnement du service frontend uniquement.
# Copier vers .env.frontend et remplir les valeurs.
# Note : ces variables ne sont jamais exposées au navigateur (pas de NEXT_PUBLIC_).

# URL interne du backend (nom du service Docker en prod, localhost en dev)
BACKEND_URL=http://backend:8000
# Même valeur que API_SECRET_KEY dans .env.backend
API_KEY=change_me_api_key
