# ── Alpaca (Paper Trading) ──────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Binance (Testnet) ────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# ── Base de données ──────────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=trading
DATABASE_URL=postgresql://trading:change_me_strong_password@db:5432/trading

# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Application ─────────────────────────────────────────────────────
ENV=development
# Générer avec: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me_in_production
# Clé API pour authentifier les requêtes du proxy Next.js
API_SECRET_KEY=change_me_api_key
# URL du frontend autorisée par le CORS (ex: http://localhost:3000 en dev, https://your-domain.com en prod)
FRONTEND_URL=http://localhost:3000
# Clé de signature JWT (hérite de API_SECRET_KEY si non définie — à personnaliser en prod)
# Générer avec: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
# Durée de validité des tokens JWT en heures (défaut: 24)
JWT_EXPIRE_HOURS=24
